<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Bote" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bote_primary</item>
        <item name="colorPrimaryDark">@color/bote_primary_dark</item>
        <item name="colorPrimaryVariant">@color/bote_primary_dark</item>
        <item name="colorAccent">@color/bote_accent</item>
        <item name="colorSecondary">@color/bote_accent</item>
        <item name="colorSecondaryVariant">@color/bote_accent</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Cabecera de sección de los formularios -->
    <style name="Bote.TextoSeccion" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

