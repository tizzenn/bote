<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/ajustes_titulo"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Panel de suscripción (solo lo rellena el sabor play) -->
            <LinearLayout
                android:id="@+id/panelSuscripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/seccion_identidad" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/campo_nombre_usuario"
                app:helperText="@string/nombre_usuario_ayuda">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campoNombreUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_tema" />

            <RadioGroup
                android:id="@+id/grupoTema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <RadioButton
                    android:id="@+id/radioBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_blanco" />

                <RadioButton
                    android:id="@+id/radioNegro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_negro" />

                <RadioButton
                    android:id="@+id/radioSistema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_sistema" />
            </RadioGroup>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_color_primario" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/grupoPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_color_acento" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/grupoAcento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_cobros" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCobro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ajuste_cobro" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/plantillaLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/ajuste_cobro_plantilla"
                app:helperText="@string/cobro_ayuda"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campoPlantilla"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_detector" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDetector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ajuste_detector" />

            <TextView
                android:id="@+id/detectorAyuda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/detector_ayuda"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccesoNotif"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/btn_acceso_notif"
                android:visibility="gone" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_sync_nube" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/ajuste_sync" />

            <LinearLayout
                android:id="@+id/panelSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/campo_sync_url"
                    app:helperText="@string/sync_nube_ayuda">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoSyncUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/campo_sync_key"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campoSyncKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProbarSync"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/sync_probar"
                    app:icon="@drawable/ic_sync" />
            </LinearLayout>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_auto_sync" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/auto_sync" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoSyncWifi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/auto_sync_wifi" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/auto_sync_ayuda"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_e2e" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="@string/e2e_frase"
                app:endIconMode="password_toggle"
                app:helperText="@string/e2e_ayuda">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campoFraseE2e"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_notificaciones" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_evento" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCierre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_cierre" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPagos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_pagos" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
