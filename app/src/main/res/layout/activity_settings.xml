<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/ajustes_titulo"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/seccion_tema" />

            <RadioGroup
                android:id="@+id/grupoTema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <RadioButton
                    android:id="@+id/radioBlanco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_blanco" />

                <RadioButton
                    android:id="@+id/radioNegro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_negro" />

                <RadioButton
                    android:id="@+id/radioSistema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tema_sistema" />
            </RadioGroup>

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_color_primario" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/grupoPrimario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_color_acento" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/grupoAcento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView
                style="@style/Bote.TextoSeccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/seccion_notificaciones" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_evento" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCierre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_cierre" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPagos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/notif_pagos" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
